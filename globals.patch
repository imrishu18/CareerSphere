  +
  +    --muted: 240 10% 96%;
  +    --muted-foreground: 240 6% 40%;
  +
  +    --accent: 280 85% 65%;            /* magenta accent */
  +    --accent-foreground: 0 0% 100%;
  +
  +    --destructive: 0 85% 60%;
  +    --destructive-foreground: 0 0% 98%;
  +
  +    --border: 240 10% 85%;
  +    --input: 240 10% 85%;
  +    --ring: 265 80% 55%;
  +
  +    --chart-1: 265 80% 55%;  /* purple */
  +    --chart-2: 192 90% 45%;  /* teal */
  +    --chart-3: 43 90% 55%;   /* yellow */
  +    --chart-4: 340 75% 60%;  /* pink */
  +    --chart-5: 200 85% 50%;  /* cyan */
  +
  +    --radius: 0.75rem;
  +  }
  +
  +  .dark {
  +    --background: 240 15% 8%;
  +    --foreground: 0 0% 98%;
  +    --card: 240 15% 12%;
  +    --card-foreground: 0 0% 98%;
  +    --popover: 240 15% 12%;
  +    --popover-foreground: 0 0% 98%;
  +
  +    --primary: 265 80% 60%;
  +    --primary-foreground: 0 0% 100%;
  +
  +    --secondary: 192 90% 50%;
  +    --secondary-foreground: 0 0% 100%;
  +
  +    --muted: 240 12% 18%;
  +    --muted-foreground: 240 8% 70%;
  +
  +    --accent: 280 80% 65%;
  +    --accent-foreground: 0 0% 100%;
  +
  +    --destructive: 0 70% 40%;
  +    --destructive-foreground: 0 0% 98%;
  +
  +    --border: 240 10% 25%;
  +    --input: 240 10% 25%;
  +    --ring: 265 80% 60%;
  +
  +    --chart-1: 265 80% 60%;
  +    --chart-2: 192 90% 50%;
  +    --chart-3: 43 90% 60%;
  +    --chart-4: 340 75% 65%;
  +    --chart-5: 200 85% 55%;
  +  }
  +}
  +
  +@layer base {
  +  * {
  +    @apply border-border;
  +  }
  +  body {
  +    @apply bg-background text-foreground;
  +  }
  +}
  +
  +@layer utilities {
  +  /* 🔹 Gradient Background */
  +  .gradient {
  +    @apply bg-gradient-to-b from-indigo-700 via-purple-700 to-violet-900;
  +  }
  +
  +  /* 🔹 Gradient Title Text */
  +  .gradient-title {
  +    @apply bg-gradient-to-r from-indigo-400 via-purple-500 to-teal-400 
  +           font-extrabold tracking-tight text-transparent bg-clip-text;
  +  }
  +}
  +
  +/* Hero section 3D effect */
  +.hero-image-wrapper {
  +  perspective: 1000px;
  +}
  +
  +.hero-image {
  +  transform: rotateX(15deg) scale(1);
  +  transition: transform 0.5s ease-out;
  +  will-change: transform;
  +}
  +
  +.hero-image.scrolled {
  +  transform: rotateX(0deg) scale(1) translateY(40px);
  +}
  +
  +/* 🔹 Neon Grid Background */
  +.grid-background {
  +  position: fixed;
  +  top: 0;
  +  left: 0;
  +  width: 100%;
  +  height: 100%;
  +  background: linear-gradient(
  +      to right,
  +      rgba(120, 120, 255, 0.15) 1px,
  +      transparent 1px
  +    ),
  +    linear-gradient(
  +      to bottom,
  +      rgba(120, 255, 220, 0.15) 1px,
  +      transparent 1px
  +    );
  +  background-size: 50px 50px;
  +  pointer-events: none;
  +  z-index: -1;
  +}
  +
  +.grid-background::before {
  +  content: "";
  +  position: absolute;
  +  top: 0;
  +  left: 0;
  +  width: 100%;
  +  height: 100%;
  +  background: radial-gradient(circle, rgba(0, 0, 0, 0) 70%, rgba(0, 0, 0, 0.85));
  +}
